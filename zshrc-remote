#!/bin/zsh
# CLAUDE EDIT NOTICE: When you change THIS file (zshrc-remote), bump
# ZSHRC_VERSION below by 1. Shows in the user's prompt as [v46] etc. —
# their signal that the zshrc push went live. Do NOT bump for edits to
# if-install.sh, if-u.sh, if-check.sh, if-claude.md — those don't
# affect the user's shell and the counter would drift meaninglessly.
ZSHRC_VERSION="54"

# Update Claude Code, set built in auto-updater off (not currently used)
# brew upgrade --cask claude-code 2>&1 | grep -v "Warning:"
# export DISABLE_AUTOUPDATER=1

# Remove mac osx terminal keybindings that interfere with claude code CLI
bindkey -r '^T'
bindkey -r '^B'

# ---- Environment ----
# Homebrew PATH/MANPATH/INFOPATH.
eval "$(/opt/homebrew/bin/brew shellenv)"

# JAVA_HOME via macOS java_home — only set if a JDK actually resolves.
# /usr/libexec/java_home always exists but prints an error to stderr when no
# Java is installed.
if _jh="$(/usr/libexec/java_home 2>/dev/null)"; then
  export JAVA_HOME="$_jh"
fi
unset _jh

# Google Cloud SDK
[ -f "$HOME/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/google-cloud-sdk/path.zsh.inc"

# Node Version Manager (non-interactive safe)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" > /dev/null 2>&1

# ---- PATH setup ----
# macOS /etc/zprofile runs path_helper before zshrc, so PATH ordering is
# asserted here (after path_helper) rather than earlier where prepends would
# be clobbered. Helpers guard on existence so the same file is portable
# across machines without breaking PATH.
prepend_path() { [[ -d "$1" ]] && export PATH="$1:$PATH"; }
append_path()  { [[ -d "$1" ]] && export PATH="$PATH:$1"; }

append_path "$HOME/bin"
append_path "$HOME/.local/bin"
if [[ -n "$JAVA_HOME" ]]; then
  prepend_path "$JAVA_HOME/bin"
else
  prepend_path "$HOME/.if/java/Contents/Home/bin"
fi
prepend_path "/Library/Developer/CommandLineTools/usr/bin"
prepend_path "/opt/homebrew/opt/ruby/bin"

# Load pyenv automatically (only if installed)
if [[ -d "$HOME/.pyenv/shims" ]]; then
  export PYENV_ROOT="$HOME/.pyenv"
  prepend_path "$PYENV_ROOT/shims"
  eval "$(pyenv init - zsh)"
fi

# Simple prompt with version number
export PS1="%F{green}[v${ZSHRC_VERSION}]%f %F{cyan}%~%f > "

# Aliases - General
alias ll="ls -al"

# Auto-select node from .nvmrc if present
[ -f .nvmrc ] && nvm use --silent