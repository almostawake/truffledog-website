#!/bin/zsh
ZSHRC_VERSION="35"

# Update Claude Code, set built in auto-updater off (not currently used)
# brew upgrade --cask claude-code 2>&1 | grep -v "Warning:"
# export DISABLE_AUTOUPDATER=1

# Remove mac osx terminal keybindings that interfere with claude code CLI
bindkey -r '^T'
bindkey -r '^B'

# ---- PATH setup ----
# Authoritative for interactive shells. macOS /etc/zprofile runs path_helper
# before zshrc, so we assert ordering here (after path_helper) rather than in
# zshenv-remote where prepends would be clobbered. Helpers guard on existence
# so the same file is portable across machines without breaking PATH.
prepend_path() { [[ -d "$1" ]] && export PATH="$1:$PATH"; }
append_path()  { [[ -d "$1" ]] && export PATH="$PATH:$1"; }

append_path "$HOME/bin"
append_path "$HOME/.local/bin"
[[ -n "$JAVA_HOME" ]] && prepend_path "$JAVA_HOME/bin"
prepend_path "/Library/Developer/CommandLineTools/usr/bin"
prepend_path "/opt/homebrew/opt/ruby/bin"

export CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL=1

# Node version selection from .nvmrc (resolves against installed nvm versions,
# no nvm use/install — fast and non-interactive)
if [ -f .nvmrc ]; then
  NVMRC_CONTENT=$(cat .nvmrc)
  CLEAN_VERSION=$(echo "$NVMRC_CONTENT" | sed 's/^v//' | sed 's/^lts\///')
  if [ "$NVMRC_CONTENT" = "lts/*" ]; then
    MATCHED_VERSION=$(ls "$NVM_DIR/versions/node" 2>/dev/null | grep -E '^v[0-9]+\.' | sed 's/^v//' | awk -F. '{if ($1 % 2 == 0) print}' | sort -V | tail -1)
  elif echo "$NVMRC_CONTENT" | grep -q "^lts/"; then
    case "$CLEAN_VERSION" in
      "krypton")  MAJOR="24" ;;
      "jod")      MAJOR="22" ;;
      "iron")     MAJOR="20" ;;
      "hydrogen") MAJOR="18" ;;
      *)          MAJOR="" ;;
    esac
    if [ -n "$MAJOR" ]; then
      MATCHED_VERSION=$(ls "$NVM_DIR/versions/node" 2>/dev/null | grep -E "^v${MAJOR}\." | sed 's/^v//' | sort -V | tail -1)
    fi
  else
    DOT_COUNT=$(echo "$CLEAN_VERSION" | tr -cd '.' | wc -c)
    if [ "$DOT_COUNT" -eq 2 ]; then
      MATCHED_VERSION=$(ls "$NVM_DIR/versions/node" 2>/dev/null | grep -E "^v${CLEAN_VERSION}$" | sed 's/^v//')
    else
      MATCHED_VERSION=$(ls "$NVM_DIR/versions/node" 2>/dev/null | grep -E "^v${CLEAN_VERSION}\." | sed 's/^v//' | sort -V | tail -1)
    fi
  fi
  [ -n "$MATCHED_VERSION" ] && prepend_path "$NVM_DIR/versions/node/v$MATCHED_VERSION/bin"
fi

# Load pyenv automatically (only if installed)
if [[ -d "$HOME/.pyenv/shims" ]]; then
  export PYENV_ROOT="$HOME/.pyenv"
  prepend_path "$PYENV_ROOT/shims"
  eval "$(pyenv init - zsh)"
fi

# Simple prompt with version number
export PS1="%F{green}[v${ZSHRC_VERSION}]%f %F{cyan}%~%f > "

# Aliases - General
alias ll="ls -al"
alias cc="claude --dangerously-skip-permissions"
ch() { killall -9 "Google Chrome" 2>/dev/null; while pgrep -qf "Google Chrome"; do sleep 0.5; done; /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222 --user-data-dir="$HOME/chrome-claude-profile" &>/dev/null & disown; for i in $(seq 1 20); do sleep 0.5; curl -s http://localhost:9222/json/version >/dev/null 2>&1 && break; done; local wspath=$(curl -s http://localhost:9222/json/version | python3 -c "import sys,json; url=json.load(sys.stdin)['webSocketDebuggerUrl']; print(url.split('9222')[1])"); printf "9222\n${wspath}" > "$HOME/Library/Application Support/Google/Chrome/DevToolsActivePort"; echo "Chrome started (debug port 9222)"; }

# Aliases & functions - Firebase Emulators
alias ca="find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && find . -name \"__pycache__\" -type d -prune -exec rm -rf '{}' + && find . -name \"venv\" -type d -prune -exec rm -rf '{}' + && find . -name \"build\" -type d -prune -exec rm -rf '{}' + && find . -name \"dist\" -type d -prune -exec rm -rf '{}' + && find . -name \"coverage\" -type d -prune -exec rm -rf '{}' + && find . -name \".vite\" -type d -prune -exec rm -rf '{}' + && find . -name \".eslintcache\" -type f -delete && find . -name \".dccache\" -type d -prune -exec rm -rf '{}' + && find . -name \"package-lock.json\" -type f -delete"
alias ia="npm run install:all"
alias ba="npm run build:all"
wa() { npm run build:common:watch & npm run build:functions:watch & wait; }
alias se="npm run start:emulators"
ra() {
  local R="\033[0m"
  local B="\033[1;36m"
  echo ""
  echo "${B}==============================================${R}"
  echo "${B}  [RA] STEP 1/2: gcloud application-default login${R}"
  echo "${B}==============================================${R}"
  echo ""
  gcloud auth application-default login
  echo ""
  echo "${B}==============================================${R}"
  echo "${B}  [RA] STEP 1/2 DONE → STEP 2/2: firebase login --reauth${R}"
  echo "${B}==============================================${R}"
  echo ""
  npx firebase login --reauth
  echo ""
  echo "${B}==============================================${R}"
  echo "${B}  [RA] STEP 2/2 DONE. Auth complete.${R}"
  echo "${B}==============================================${R}"
  echo ""
}
alias sc="npm run start:client"
alias bs="curl -X POST http://127.0.0.1:5001/bean-development/australia-southeast1/admin/bootstrap"
alias sp="ports=\$(lsof -nP -i :9099 -i :5001 -i :8080 -i :5002 -i :9199 -i :8085 2>/dev/null | awk 'NR>1 {print \$9}' | sed 's/.*://' | sed 's/->.*//' | sort -n | uniq | xargs); [ -n \"\$ports\" ] && echo \"Ports taken: \$ports\" || echo \"All ports free\""
alias kp="lsof -ti :9099 -ti :5001 -ti :8080 -ti :5002 -ti :9199 -ti :8085 -ti :3000 -ti :4400 | xargs kill"
alias 'kp!'="kill -9 \$(lsof -ti :9099 -ti :5001 -ti :8080 -ti :5002 -ti :9199 -ti :8085 -ti :3000 -ti :4400)"

# List aliases/commands
c() {
  echo "Shortcuts:"
  echo ""
  echo "  ca    clear all cache directories and files including package-lock.json"
  echo "  ia    install:all"
  echo "  ba    build:all"
  echo "  wa    watch functions/common (concurrently)"
  echo "  se    start emulators"
  echo "  ra    reauth: gcloud auth + firebase login"
  echo "  sc    start client"
  echo "  bs    run bootstrap"
  echo "  sp    show emulator ports in use"
  echo "  kp    graceful kill emulator ports (SIGTERM)"
  echo "  kp!   force kill emulator ports (SIGKILL)"
  echo "  cc    claude --dangerously-skip-permissions"
  echo "  ch    launch Chrome with remote debugging (port 9222)"
}