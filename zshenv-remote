#!/bin/zsh
# CLAUDE EDIT NOTICE: When editing this file, bump ZSHRC_VERSION in
# zshrc-remote by 1. Shows in user's prompt as [v38] etc. — their signal
# that the push went live.
#
# zshenv: env vars only (sourced by every zsh invocation, including scripts).
# PATH ordering lives in zshrc-remote because macOS /etc/zprofile runs
# /usr/libexec/path_helper, which rebuilds PATH and clobbers any prepends
# made here for login shells.

# Set PATH, MANPATH, etc., for Homebrew.
eval "$(/opt/homebrew/bin/brew shellenv)"

# Set JAVA_HOME using macOS java_home utility. Only if it actually resolves a
# JDK — /usr/libexec/java_home always exists on macOS but prints an "Unable to
# locate a Java Runtime" error to stderr when no Java is installed.
if _jh="$(/usr/libexec/java_home 2>/dev/null)"; then
  export JAVA_HOME="$_jh"
fi
unset _jh

# Google Cloud SDK
[ -f '/Users/wombat/google-cloud-sdk/path.zsh.inc' ] && . '/Users/wombat/google-cloud-sdk/path.zsh.inc'

# Node Version Manager - Non-interactive safe version
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" > /dev/null 2>&1
